#!/bin/sh
# Pre-commit hook: type-check always, tests always, coverage only in worktrees
set -e

# Git hooks inherit env vars that break git tests
unset GIT_INDEX_FILE
unset GIT_DIR
unset GIT_WORK_TREE
unset GIT_OBJECT_DIRECTORY

echo "🔍 Running pre-commit checks..."

if ! npm run c 2>/dev/null; then
  echo "❌ Type-check failed — fix errors before committing"
  exit 1
fi

# In worktrees (.git is a file, not a dir), also enforce coverage
if [ -f .git ]; then
  echo "   (worktree detected — enforcing coverage)"
  if ! npm run tc 2>/dev/null; then
    echo "❌ Coverage dropped below 100% — add tests for new code"
    exit 1
  fi
else
  if ! npm run t 2>/dev/null; then
    echo "❌ Tests failed — fix failures before committing"
    exit 1
  fi
fi

echo "✅ Pre-commit checks passed"
