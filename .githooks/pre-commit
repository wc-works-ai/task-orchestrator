#!/bin/sh
# Pre-commit hook: fast feedback — type-check + unit tests only.
# Coverage is enforced at pre-push (npm run tc) and, for agent work, at merge
# via ORCH_VERIFY_CMD.
set -e

# Git hooks inherit env vars that break git tests
unset GIT_INDEX_FILE
unset GIT_DIR
unset GIT_WORK_TREE
unset GIT_OBJECT_DIRECTORY

echo "🔍 Running pre-commit checks..."

if ! npm run c 2>/dev/null; then
  echo "❌ Type-check failed — fix errors before committing"
  exit 1
fi

if ! npm run test:unit 2>/dev/null; then
  echo "❌ Unit tests failed — fix failures before committing"
  exit 1
fi

echo "✅ Pre-commit checks passed"
