#!/bin/sh
# Pre-push hook: run full pipeline, reject push on failure
set -e

# Git hooks inherit env vars that break git tests
unset GIT_INDEX_FILE
unset GIT_DIR
unset GIT_WORK_TREE
unset GIT_OBJECT_DIRECTORY

echo "🔍 Running pre-push checks..."

# Lint + type-check + coverage + build
npm run pkg:lint && npm run c && npm run tc && npm run b

# Check for unstaged changes (test files updated but not staged)
if ! git diff --quiet -- tests/; then
  echo "⚠️  Unstaged changes in tests/ — stage them or stash before pushing"
  exit 1
fi

echo "✅ All checks passed"
