{
  "name": "task-orchestrator",
  "version": "0.0.1",
  "type": "module",
  "description": "Autonomous task execution engine with atomic claiming, convergence tracking, and sharded state",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "orchestrator": "./bin.mjs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "bin.mjs"
  ],
  "sideEffects": false,
  "scripts": {
    "test": "npm run t",
    "test:watch": "npm run tw",
    "test:coverage": "npm run tc",
    "typecheck": "npm run c",
    "build": "npm run b",
    "pkg:lint": "node -e \"const s=require('./package.json').scripts;const r=['test','test:watch','test:coverage','typecheck','build','prepublishOnly','test:unit','test:int','test:e2e','test:all','cov:unit'];const a=['t','tw','tc','c','b'];r.forEach(k=>{if(!s[k]){console.error('Missing canonical script: '+k);process.exit(1)}});a.forEach(k=>{if(!s[k]){console.error('Missing shortcut script: '+k);process.exit(1)}})\"",
    "t": "vitest run",
    "tw": "vitest",
    "tc": "vitest run --project unit --project integration --coverage",
    "test:unit": "vitest run --project unit",
    "test:int": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e --passWithNoTests",
    "test:all": "vitest run",
    "cov:unit": "vitest run --project unit --coverage --coverage.thresholds.100=false",
    "c": "tsc --noEmit",
    "b": "tsc --project tsconfig.build.json",
    "dev": "tsx --watch src/cli.ts",
    "loop": "tsx src/cli.ts --loop",
    "stat": "tsx src/cli.ts --status",
    "all": "npm run pkg:lint && npm run c && npm run t && npm run b",
    "preversion": "npm run all",
    "version": "npm run b && git add dist/",
    "postversion": "git push --follow-tags",
    "prepublishOnly": "npm run all",
    "tick": "tsx src/cli.ts",
    "help": "tsx src/cli.ts --help",
    "check": "tsx src/cli.ts --check",
    "stop": "tsx src/cli.ts --stop",
    "add": "tsx src/cli.ts add"
  },
  "keywords": [
    "orchestrator",
    "task-runner",
    "autonomous",
    "convergence",
    "claim-based"
  ],
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
